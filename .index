    <!-- ================= CONTACT ================= -->


    <section class="contact" id="contact">

        <h2 class="section-title">Contact Us</h2>

        <p class="contact-text">
            We'd love to hear from you! Feel free to contact us for any questions or support.
        </p>

        <div class="contact-container">

            <!-- Contact Information -->

            <div class="contact-info">

                <h3>Get In Touch</h3>

                <p>📍 Karachi, Pakistan</p>

                <p>📞 +92 300 1234567</p>

                <p>📧 bagbagstore@gmail.com</p>

                <p>🕒 Mon - Sat : 9:00 AM - 8:00 PM</p>

            </div>

            <!-- Contact Form -->

            <div class="contact-form">

                <form onsubmit="return contactForm()">

                    <input type="text" id="cname" placeholder="Your Name">

                    <input type="email" id="cemail" placeholder="Your Email">

                    <input type="text" id="csubject" placeholder="Subject">

                    <textarea id="cmessage" rows="6" placeholder="Your Message"></textarea>

                    <button type="submit">
                        Send Message
                    </button>

                </form>

            </div>

        </div>

    </section>

    <!-- ================= DOWNLOAD ================= -->

    <section class="download">

        <h2 class="section-title">Download Our Catalogue</h2>

        <p class="paragraph">Click the button below to download our latest bag catalogue.</p>
        <br>
        <br>


        <a href="pdf/catalogue.pdf" download>
            <button class="download-btn">
                Download PDF
            </button>
        </a>

    </section>
